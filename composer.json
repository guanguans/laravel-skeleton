    "repositories": {
        "facade-documenter": {
            "type": "vcs",
            "url": "git@github.com:laravel/facade-documenter.git"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "carthage-software/mago": true,
            "cweagans/composer-patches": false,
            "ergebnis/composer-normalize": true,
            "ion-bazan/composer-diff": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/runtime": true,
            "symfony/thanks": true,
            "wikimedia/composer-merge-plugin": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": false,
            "target-directory": "vendor-bin"
        },
        "composer-attribute-collector": {
            "exclude": [
                "app/Support/PhpCsFixer/",
                "{vendor}/symplify/rule-doc-generator/"
            ],
            "include": [
                "app/"
            ]
        },
        "hooks": {
            "post-merge": [
                "composer install --ansi -vv",
                "composer checks:required"
            ],
            "pre-commit": [
                "composer checks:required"
            ]
        },
        "laravel": {
            "dont-discover": [
                "amirami/localizator",
                "andreaselia/laravel-api-to-postman",
                "barryvdh/laravel-ide-helper",
                "beyondcode/laravel-query-detector",
                "binarytorch/larecipe",
                "dedoc/scramble",
                "dragon-code/migrate-db",
                "dragon-code/pretty-routes",
                "guanguans/laravel-soar",
                "jasonmccreary/laravel-test-assertions",
                "josezenem/laravel-make-migration-pivot",
                "kitloong/laravel-migrations-generator",
                "knuckleswtf/scribe",
                "laracraft-tech/laravel-schema-rules",
                "laravel-shift/factory-generator",
                "laravel/dusk",
                "laravel/pail",
                "laravel/roster",
                "laravel/sail",
                "laravel/telescope",
                "msamgan/laravel-env-keys-checker",
                "muhammadhuzaifa/telescope-guzzle-watcher",
                "nunomaduro/collision",
                "orangehill/iseed",
                "rakutentech/laravel-request-docs",
                "reliese/laravel",
                "scalar/laravel",
                "soloterm/dumps",
                "soloterm/solo",
                "spatie/laravel-error-solutions",
                "spatie/laravel-horizon-watcher",
                "spatie/laravel-ignition",
                "spatie/laravel-login-link",
                "spatie/laravel-stubs",
                "sti3bas/laravel-scout-array-driver",
                "thedoctor0/laravel-factory-generator",
                "vcian/laravel-db-auditor",
                "worksome/envy",
                "worksome/request-factories"
            ]
        },
        "phpstan/extension-installer": {
            "ignore": [
                "sidz/phpstan-rules"
            ]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@cghooks:upsert",
            "@composer:normalize"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --force --ansi -vv",
            "@artisan vendor:publish --tag=laravel-errors",
            "@artisan log-viewer:publish",
            "@cghooks:upsert",
            "@composer:normalize"
        ],
        "pre-autoload-dump": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\""
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi -vv"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi -vv",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi -vv"
        ],
        "actionlint": "actionlint -ignore=SC2035 -ignore=SC2046 -ignore=SC2086 -color -oneline -verbose",
        "app:fix-neon": "Guanguans\\PHPStanRules\\Support\\ComposerScripts::fixNeon",
        "app:generate-gitleaks-ignore": "Guanguans\\Notify\\Foundation\\Support\\ComposerScripts::generateGitleaksIgnore",
        "app:install-project": [
            "@post-create-project-cmd",
            "@artisan jwt:secret --force"
        ],
        "app:lint-readme": "App\\Support\\ComposerScripts::lintReadme",
        "app:parse-phpdoc": "Guanguans\\RectorRules\\Support\\ComposerScripts::parsePhpdoc",
        "argtyper": "@php vendor/bin/argtyper --ansi -vv",
        "argtyper:add-types": "@argtyper add-types .",
        "artisan": "@php artisan --ansi -vv",
        "artisan:envy-prune": "@artisan envy:prune",
        "artisan:envy-sync": "@artisan envy:sync",
        "artisan:ide-helper": [
            "@artisan ide-helper:eloquent",
            "@artisan ide-helper:generate",
            "@artisan ide-helper:meta",
            "@artisan ide-helper:models --nowrite"
        ],
        "artisan:solo": "@artisan solo",
        "artisan:solo-dumps": "@artisan solo:dumps",
        "artisan:xdebug": [
            "@env-put-xdebug-on",
            "@artisan"
        ],
        "blade-formatter": "blade-formatter resources/views/*.blade.php resources/views/**/*.blade.php --ignore-path= --php-version=8.5 --progress",
        "blade-formatter:check-formatted": "@blade-formatter --check-formatted",
        "blade-formatter:write": "@blade-formatter --write",
        "cghooks": "@php vendor/bin/cghooks --ansi -vv",
        "cghooks:upsert": [
            "@cghooks add --ignore-lock",
            "@cghooks update"
        ],
        "checks": [
            "@checks:required",
            "@checks:optional"
        ],
        "checks:optional": [
            "@putenv:xdebug-off",
            "@app:fix-neon",
            "@app:lint-readme",
            "@class-leak:check",
            "@composer-dependency-analyser",
            "@composer:normalize-dry-run",
            "@composer:unlink",
            "@detect-collisions",

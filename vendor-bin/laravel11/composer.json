{
    "require": {
        "php": ">=8.5"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.50",
        "symplify/rule-doc-generator": "^12.2"
    },
    "suggest": {
        "ace-of-aces/laravel-image-transform-url": "Required to use the package [ace-of-aces/laravel-image-transform-url].",
        "appstract/laravel-opcache": "Required to use the package [appstract/laravel-opcache].",
        "enlightn/enlightn": "Required to use the package [enlightn/enlightn].",
        "gordalina/cachetool": "Required to use the package [gordalina/cachetool].",
        "grazulex/laravel-sharelink": "Required to use the package [grazulex/laravel-sharelink].",
        "stechstudio/laravel-zipstream": "Required to use the package [stechstudio/laravel-zipstream].",
        "stillat/blade-directives": "Required to use the package [stillat/blade-directives]."
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "theofidry/composer-inheritance-plugin": false,
            "wikimedia/composer-merge-plugin": false
        },
        "sort-packages": true
    }
}
